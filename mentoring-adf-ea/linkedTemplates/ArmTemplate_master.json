{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "mentoring-adf-ea"
		},
		"ls_azurementoringauea_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_azurementoringauea'"
		},
		"ls_adf_azurementoringdatalakeea_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://azurementoringdatalakeea.dfs.core.windows.net/"
		},
		"ls_adf_azurementoringstorageea_properties_typeProperties_sasUri_secretName": {
			"type": "string",
			"defaultValue": "akv-azurementoringstorageea"
		},
		"ls_adf_bs_online_properties_typeProperties_sasUri_secretName": {
			"type": "string",
			"defaultValue": "akv-bs-online"
		},
		"ls_adf_db_datamart_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "akv-azuredb-datamart-connstr"
		},
		"ls_adf_db_movies_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azure-mentoring-ea.database.windows.net"
		},
		"ls_adf_db_movies_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "movies"
		},
		"ls_adf_db_movies_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sa_login"
		},
		"ls_adf_localdb_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "akv-localdbconnstr"
		},
		"ls_mentoring_adf_akv_ea_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://mentoring-key-vault-ea.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "mentoring-adf-ea_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_azurementoringauea_connectionString": {
						"value": "[parameters('ls_azurementoringauea_connectionString')]"
					},
					"ls_adf_azurementoringdatalakeea_properties_typeProperties_url": {
						"value": "[parameters('ls_adf_azurementoringdatalakeea_properties_typeProperties_url')]"
					},
					"ls_mentoring_adf_akv_ea_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_mentoring_adf_akv_ea_properties_typeProperties_baseUrl')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "mentoring-adf-ea_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adf_azurementoringstorageea_properties_typeProperties_sasUri_secretName": {
						"value": "[parameters('ls_adf_azurementoringstorageea_properties_typeProperties_sasUri_secretName')]"
					},
					"ls_adf_bs_online_properties_typeProperties_sasUri_secretName": {
						"value": "[parameters('ls_adf_bs_online_properties_typeProperties_sasUri_secretName')]"
					},
					"ls_adf_db_datamart_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('ls_adf_db_datamart_properties_typeProperties_connectionString_secretName')]"
					},
					"ls_adf_db_movies_properties_typeProperties_server": {
						"value": "[parameters('ls_adf_db_movies_properties_typeProperties_server')]"
					},
					"ls_adf_db_movies_properties_typeProperties_database": {
						"value": "[parameters('ls_adf_db_movies_properties_typeProperties_database')]"
					},
					"ls_adf_db_movies_properties_typeProperties_userName": {
						"value": "[parameters('ls_adf_db_movies_properties_typeProperties_userName')]"
					},
					"ls_adf_localdb_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('ls_adf_localdb_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'mentoring-adf-ea_ArmTemplate_0')]"
			]
		},
		{
			"name": "mentoring-adf-ea_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'mentoring-adf-ea_ArmTemplate_1')]"
			]
		},
		{
			"name": "mentoring-adf-ea_ArmTemplate_3",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_3.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'mentoring-adf-ea_ArmTemplate_2')]"
			]
		}
	]
}