						"formatSettings": {
							"type": "JsonWriteSettings"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "ds_bs_online",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_dls_online",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "act_gen_sp_write_watermark",
				"type": "SqlServerStoredProcedure",
				"dependsOn": [
					{
